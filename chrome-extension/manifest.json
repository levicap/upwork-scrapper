{
  "manifest_version": 3,
  "name": "Upwork API Capture",
  "version": "1.0.0",
  "description": "Captures all API requests on Upwork including headers, request body, and response body.",
  "permissions": [
    "debugger",
    "tabs",
    "storage",
    "alarms",
    "downloads",
    "cookies"
  ],
  "host_permissions": [
    "*://*.upwork.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Upwork API Capture"
  }
}
